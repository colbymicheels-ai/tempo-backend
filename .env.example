# Copy this file to ".env" for LOCAL testing only. On Render you set these
# in the dashboard (Environment), NOT in a committed file.

# Your Anthropic API key (from console.anthropic.com → API Keys)
ANTHROPIC_API_KEY=sk-ant-...

# Your deployed backend's base URL (fill in AFTER the first deploy).
# e.g. https://tempo-backend-xxxx.onrender.com
PUBLIC_URL=

# Which Claude model the proxy uses. Change only if your account needs another id.
MODEL=claude-haiku-4-5

# Where the Garmin token is stored. Default is fine.
TOKEN_FILE=./garmin-token.json

# Which web origins may call this backend. "*" is fine for personal use.
ALLOWED_ORIGIN=*
